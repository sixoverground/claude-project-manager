#!/bin/zsh
set -euo pipefail

# --- Config ---
SCRIPT_PATH="${0:A}"
PROJECT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECTS_FILE="$PROJECT_DIR/projects.json"
PLIST_NAME="com.sixoverground.claude-orchestrator"
PLIST_SRC="$PROJECT_DIR/$PLIST_NAME.plist"
PLIST_DST="$HOME/Library/LaunchAgents/$PLIST_NAME.plist"
LOG_DIR="$HOME/Library/Logs/claude-orchestrator"
LOCK_FILE="/tmp/claude-orchestrator.lock"
MERGE_WINDOW_HOURS=4
ACTIVITY_WINDOW_HOURS=2
DISPATCH_COOLDOWN_HOURS=2
DISPATCH_MAX_RETRIES=3
DEFAULT_BRANCH_PREFIX="claude/"
STATE_FILE="$PROJECT_DIR/.cpm-state.json"

# Ensure PATH includes required binaries (critical for launchd)
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$HOME/.nvm/versions/node/v24.14.0/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# --- Helpers ---
log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

log_to_file() {
  mkdir -p "$LOG_DIR"
  local logfile="$LOG_DIR/orchestrator-$(date +%Y-%m-%d).log"
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$logfile"
}

hours_since() {
  local iso_date="$1"
  local then_epoch now_epoch
  # Strip fractional seconds and handle Z suffix
  local clean_date="${iso_date%%.*}"
  clean_date="${clean_date%Z}"
  then_epoch=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%S" "$clean_date" "+%s" 2>/dev/null || echo "0")
  now_epoch=$(date "+%s")
  echo $(( (now_epoch - then_epoch) / 3600 ))
}

time_ago() {
  local iso_date="$1"
  local then_epoch now_epoch diff_seconds
  local clean_date="${iso_date%%.*}"
  clean_date="${clean_date%Z}"
  then_epoch=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%S" "$clean_date" "+%s" 2>/dev/null || echo "0")
  now_epoch=$(date "+%s")
  diff_seconds=$(( now_epoch - then_epoch ))
  if [ "$diff_seconds" -lt 3600 ]; then
    echo "$(( diff_seconds / 60 ))m ago"
  else
    echo "$(( diff_seconds / 3600 ))h ago"
  fi
}

cleanup_logs() {
  if [ -d "$LOG_DIR" ]; then
    find "$LOG_DIR" -name "orchestrator-*.log" -mtime +14 -delete 2>/dev/null || true
    for f in "$LOG_DIR/launchd-stdout.log" "$LOG_DIR/launchd-stderr.log"; do
      if [ -f "$f" ] && [ $(stat -f%z "$f" 2>/dev/null || echo 0) -gt 1048576 ]; then
        tail -1000 "$f" > "$f.tmp" && mv "$f.tmp" "$f"
      fi
    done
  fi
}

ensure_state_file() {
  [ -f "$STATE_FILE" ] || echo '{}' > "$STATE_FILE"
}

state_get() {
  local name="$1" field="$2"
  ensure_state_file
  jq -r --arg n "$name" --arg f "$field" '.[$n][$f] // empty' "$STATE_FILE"
}

state_record_dispatch() {
  local name="$1" pr_key="$2"
  ensure_state_file
  local prev_pr prev_count new_count
  prev_pr=$(state_get "$name" "last_dispatched_for_pr")
  prev_count=$(state_get "$name" "dispatch_count")
  new_count=1
  if [ "$prev_pr" = "$pr_key" ] && [ -n "$prev_count" ]; then
    new_count=$((prev_count + 1))
  fi
  local now tmp
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  tmp="$STATE_FILE.tmp"
  jq --arg n "$name" --arg pr "$pr_key" --arg ts "$now" --argjson count "$new_count" \
    '.[$n] = {last_dispatched_for_pr: $pr, last_dispatched_at: $ts, dispatch_count: $count}' \
    "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

_render_plist() {
  local user="$1" home="$2" brew_prefix="$3" project_dir="$4"
  local tmpl="$PROJECT_DIR/templates/$PLIST_NAME.plist.tmpl"
  local path_value="$brew_prefix/bin:$brew_prefix/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
  sed -e "s|{{USER}}|$user|g" \
      -e "s|{{HOME}}|$home|g" \
      -e "s|{{PROJECT_DIR}}|$project_dir|g" \
      -e "s|{{PATH}}|$path_value|g" \
      "$tmpl"
}

# --- Subcommand: run ---
cmd_run() {
  # Lock guard
  if [ -f "$LOCK_FILE" ]; then
    local lock_pid
    lock_pid=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
    if [ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
      log "Another instance is running (PID $lock_pid). Exiting."
      exit 1
    fi
    rm -f "$LOCK_FILE"
  fi
  echo $$ > "$LOCK_FILE"
  trap 'rm -f "$LOCK_FILE"' EXIT

  cleanup_logs

  log "Orchestrator run starting"
  log_to_file "=== Orchestrator run starting ==="

  local projects
  projects=$(jq -c '.projects[]' "$PROJECTS_FILE")

  # Summary rows
  local -a summary_rows=()

  while IFS= read -r project; do
    name=$(echo "$project" | jq -r '.name')
    trigger_id=$(echo "$project" | jq -r '.trigger_id')
    project_prefix=$(echo "$project" | jq -r '.branch_prefix // empty')
    paused=$(echo "$project" | jq -r '.paused')

    # Skip paused projects
    if [ "$paused" = "true" ]; then
      log_to_file "[$name] SKIP: paused"
      summary_rows+=("| $name | paused | SKIP | Project paused |")
      continue
    fi

    # Iterate repos for this project
    local repos=$(echo "$project" | jq -c '.repos[]')
    local skip_project=false
    local skip_reason=""
    local best_merged_at=""
    local best_merged_pr_num=""
    local best_merged_branch=""
    local best_merged_repo=""
    local best_hours_ago=999999

    while IFS= read -r repo_entry; do
      repo=$(echo "$repo_entry" | jq -r '.repo')
      repo_prefix=$(echo "$repo_entry" | jq -r '.branch_prefix // empty')
      # Resolve branch prefix: per-repo > project-level > default
      local branch_prefix="${repo_prefix:-${project_prefix:-$DEFAULT_BRANCH_PREFIX}}"

      # Step 1: Check for open phase PR
      open_prs=$(gh pr list --repo "$repo" --state open --search "head:$branch_prefix" --json number,headRefName 2>/dev/null || echo "[]")
      open_count=$(echo "$open_prs" | jq 'length')

      if [ "$open_count" -gt 0 ]; then
        open_pr_num=$(echo "$open_prs" | jq -r '.[0].number')
        log_to_file "[$name] SKIP: open PR #$open_pr_num in $repo"
        skip_project=true
        skip_reason="PR #$open_pr_num in progress ($repo)"
        break
      fi

      # Step 2: Check for recently merged phase PR (track best across repos)
      last_merged=$(gh pr list --repo "$repo" --state merged --search "head:$branch_prefix" --json number,mergedAt,headRefName --jq 'sort_by(.mergedAt) | last' 2>/dev/null || echo "null")

      if [ "$last_merged" != "null" ] && [ -n "$last_merged" ]; then
        merged_at=$(echo "$last_merged" | jq -r '.mergedAt')
        merged_pr_num=$(echo "$last_merged" | jq -r '.number')
        merged_branch=$(echo "$last_merged" | jq -r '.headRefName')
        hours_ago=$(hours_since "$merged_at")

        if [ "$hours_ago" -lt "$best_hours_ago" ]; then
          best_merged_at="$merged_at"
          best_merged_pr_num="$merged_pr_num"
          best_merged_branch="$merged_branch"
          best_merged_repo="$repo"
          best_hours_ago="$hours_ago"
        fi
      fi

      # Step 3: Guard against active sessions
      # /repos/X/branches doesn't return committer.date, so use the GraphQL refs API instead.
      local owner_name="${repo%%/*}"
      local repo_short="${repo##*/}"
      last_activity=$(gh api graphql \
        -f query='query($owner: String!, $repo: String!, $prefix: String!) { repository(owner: $owner, name: $repo) { refs(refPrefix: $prefix, first: 100) { nodes { target { ... on Commit { committedDate } } } } } }' \
        -F owner="$owner_name" -F repo="$repo_short" -F prefix="refs/heads/$branch_prefix" \
        --jq '[.data.repository.refs.nodes[].target.committedDate] | sort | last' 2>/dev/null || echo "")

      if [ -n "$last_activity" ] && [ "$last_activity" != "null" ]; then
        activity_hours=$(hours_since "$last_activity")
        if [ "$activity_hours" -lt "$ACTIVITY_WINDOW_HOURS" ]; then
          local activity_ago=$(time_ago "$last_activity")
          log_to_file "[$name] SKIP: recent branch activity $activity_ago in $repo"
          skip_project=true
          skip_reason="Session likely active ($repo, $activity_ago)"
          break
        fi
      fi
    done <<< "$repos"

    # Handle skip
    if [ "$skip_project" = "true" ]; then
      summary_rows+=("| $name | open PR | SKIP | $skip_reason |")
      continue
    fi

    # No merged PRs found across any repo
    if [ -z "$best_merged_at" ]; then
      log_to_file "[$name] SKIP: no merged PRs found"
      summary_rows+=("| $name | no merge | SKIP | No merged PRs found |")
      continue
    fi

    local best_time_ago=$(time_ago "$best_merged_at")

    # Dispatch dedup: each merged PR gets at most DISPATCH_MAX_RETRIES dispatches,
    # spaced by DISPATCH_COOLDOWN_HOURS. Prevents runaway dispatches when the
    # trigger can't open a PR quickly enough for the open-PR / activity guards.
    local pr_key="${best_merged_repo}#${best_merged_pr_num}"
    local prev_pr prev_at prev_count
    prev_pr=$(state_get "$name" "last_dispatched_for_pr")
    prev_at=$(state_get "$name" "last_dispatched_at")
    prev_count=$(state_get "$name" "dispatch_count")

    if [ "$prev_pr" = "$pr_key" ]; then
      if [ "${prev_count:-0}" -ge "$DISPATCH_MAX_RETRIES" ]; then
        log_to_file "[$name] SKIP: max retries ($DISPATCH_MAX_RETRIES) reached for $pr_key"
        summary_rows+=("| $name | merged $best_time_ago | SKIP | Max retries hit for #$best_merged_pr_num |")
        continue
      fi
      if [ -n "$prev_at" ]; then
        local cooldown_hours
        cooldown_hours=$(hours_since "$prev_at")
        if [ "$cooldown_hours" -lt "$DISPATCH_COOLDOWN_HOURS" ]; then
          local cooldown_ago
          cooldown_ago=$(time_ago "$prev_at")
          log_to_file "[$name] SKIP: dispatched $cooldown_ago (cooldown ${DISPATCH_COOLDOWN_HOURS}h)"
          summary_rows+=("| $name | merged $best_time_ago | SKIP | Dispatched $cooldown_ago, cooling |")
          continue
        fi
      fi
    fi

    # Exception: merged > 4h ago + no open PR + no recent branch activity → dispatch anyway
    if [ "$best_hours_ago" -gt "$MERGE_WINDOW_HOURS" ]; then
      log_to_file "[$name] DISPATCH (exception): PR #$best_merged_pr_num merged $best_time_ago, no open PR, no recent activity (previous run may have failed)"
    fi

    # Step 4: Dispatch
    log "[$name] DISPATCH: PR #$best_merged_pr_num ($best_merged_branch) in $best_merged_repo merged $best_time_ago"
    log_to_file "[$name] DISPATCH: PR #$best_merged_pr_num ($best_merged_branch) in $best_merged_repo merged $best_time_ago"

    dispatch_output=$(claude -p \
      --allowed-tools "RemoteTrigger" \
      --dangerously-skip-permissions \
      --no-session-persistence \
      "Run the remote trigger with ID $trigger_id. Use the RemoteTrigger tool with action 'run' and trigger_id '$trigger_id'. Output only the result." \
      2>&1) || true

    log_to_file "[$name] Dispatch output: $dispatch_output"
    state_record_dispatch "$name" "$pr_key"
    summary_rows+=("| $name | merged $best_time_ago | DISPATCH | $best_merged_branch merged, starting next |")

  done <<< "$projects"

  # Print summary table
  echo ""
  echo "| Project              | Status          | Action   | Reason                          |"
  echo "|----------------------|-----------------|----------|---------------------------------|"
  for row in "${summary_rows[@]}"; do
    echo "$row"
  done
  echo ""

  log_to_file "=== Orchestrator run complete ==="
}

# --- Subcommand: status ---
cmd_status() {
  # Check launchd status
  local launchd_status
  if launchctl list "$PLIST_NAME" &>/dev/null; then
    launchd_status="running (every 30m)"
  else
    launchd_status="stopped"
  fi
  echo "Scheduler: $launchd_status"
  echo ""

  local projects
  projects=$(jq -c '.projects[]' "$PROJECTS_FILE")

  echo "| Project              | Status          | Last Merge         |"
  echo "|----------------------|-----------------|--------------------|"

  while IFS= read -r project; do
    name=$(echo "$project" | jq -r '.name')
    project_prefix=$(echo "$project" | jq -r '.branch_prefix // empty')
    paused=$(echo "$project" | jq -r '.paused')

    if [ "$paused" = "true" ]; then
      printf "| %-20s | %-15s | %-18s |\n" "$name" "paused" "-"
      continue
    fi

    local repos=$(echo "$project" | jq -c '.repos[]')
    local status_text="idle"
    local best_merge_date=""
    local best_merge_hours=999999

    while IFS= read -r repo_entry; do
      repo=$(echo "$repo_entry" | jq -r '.repo')
      repo_prefix=$(echo "$repo_entry" | jq -r '.branch_prefix // empty')
      local branch_prefix="${repo_prefix:-${project_prefix:-$DEFAULT_BRANCH_PREFIX}}"

      # Check open PRs
      open_count=$(gh pr list --repo "$repo" --state open --search "head:$branch_prefix" --json number 2>/dev/null | jq 'length' 2>/dev/null || echo "0")

      if [ "$open_count" -gt 0 ]; then
        status_text="PR open"
      fi

      # Last merged PR (track most recent across repos)
      last_merged=$(gh pr list --repo "$repo" --state merged --search "head:$branch_prefix" --json mergedAt --jq 'sort_by(.mergedAt) | last | .mergedAt' 2>/dev/null || echo "")

      if [ -n "$last_merged" ] && [ "$last_merged" != "null" ]; then
        hours_ago=$(hours_since "$last_merged")
        if [ "$hours_ago" -lt "$best_merge_hours" ]; then
          best_merge_hours="$hours_ago"
          best_merge_date="$last_merged"
        fi
      fi
    done <<< "$repos"

    if [ -n "$best_merge_date" ]; then
      merge_text=$(time_ago "$best_merge_date")
    else
      merge_text="none"
    fi

    printf "| %-20s | %-15s | %-18s |\n" "$name" "$status_text" "$merge_text"
  done <<< "$projects"

  echo ""
}

# --- Subcommand: init ---
cmd_init() {
  shift  # remove "init" from args
  local force=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=true; shift ;;
      *) echo "Unknown option: $1"; exit 1 ;;
    esac
  done

  local user home brew_prefix
  user="$(whoami)"
  home="$HOME"
  brew_prefix=$(brew --prefix 2>/dev/null || echo "/opt/homebrew")

  echo "cpm init"

  if [ ! -f "$PROJECTS_FILE" ]; then
    echo '{"projects": []}' > "$PROJECTS_FILE"
    echo "  [ok] created projects.json"
  else
    local count
    count=$(jq '.projects | length' "$PROJECTS_FILE" 2>/dev/null || echo "?")
    echo "  [skip] projects.json exists ($count projects)"
  fi

  local tmpl="$PROJECT_DIR/templates/$PLIST_NAME.plist.tmpl"
  if [ ! -f "$tmpl" ]; then
    echo "  [fail] plist template not found at $tmpl"
    exit 1
  fi
  if [ -f "$PLIST_SRC" ] && [ "$force" != "true" ]; then
    echo "  [skip] plist exists at $PLIST_SRC (use --force to regenerate)"
  else
    _render_plist "$user" "$home" "$brew_prefix" "$PROJECT_DIR" > "$PLIST_SRC"
    echo "  [ok] generated $PLIST_SRC"
  fi

  if ! command -v cpm &>/dev/null; then
    echo "  [warn] cpm is not on \$PATH"
    echo "         Optional: ln -s \"$PROJECT_DIR/cpm\" $brew_prefix/bin/cpm"
  else
    echo "  [ok] cpm on \$PATH"
  fi

  echo ""
  echo "Next steps:"
  echo "  1. cpm doctor       # verify gh / jq / claude are installed and authenticated"
  echo "  2. cpm new <name>   # walk through setup for your first project"
  echo "  3. cpm start        # enable the 30-min launchd scheduler"
}

# --- Subcommand: doctor ---
cmd_doctor() {
  local fails=0

  echo "cpm doctor"

  if command -v claude &>/dev/null; then
    echo "  [ok]   claude:        $(claude --version 2>&1 | head -1)"
  else
    echo "  [fail] claude:        not installed (https://docs.anthropic.com/en/docs/claude-code)"
    fails=$((fails+1))
  fi

  if command -v gh &>/dev/null; then
    echo "  [ok]   gh:            $(gh --version 2>&1 | head -1)"
  else
    echo "  [fail] gh:            not installed (https://cli.github.com)"
    fails=$((fails+1))
  fi

  if gh auth status &>/dev/null; then
    echo "  [ok]   gh auth:       logged in"
  else
    echo "  [fail] gh auth:       not authenticated (run 'gh auth login')"
    fails=$((fails+1))
  fi

  if command -v jq &>/dev/null; then
    echo "  [ok]   jq:            $(jq --version 2>&1)"
  else
    echo "  [fail] jq:            not installed (brew install jq)"
    fails=$((fails+1))
  fi

  if [ -f "$PROJECTS_FILE" ]; then
    if jq -e '.projects' "$PROJECTS_FILE" &>/dev/null; then
      local count
      count=$(jq '.projects | length' "$PROJECTS_FILE")
      echo "  [ok]   projects.json: parses ($count projects)"
    else
      echo "  [fail] projects.json: invalid JSON or missing .projects array"
      fails=$((fails+1))
    fi
  else
    echo "  [fail] projects.json: missing (run 'cpm init')"
    fails=$((fails+1))
  fi

  if [ -f "$PLIST_SRC" ]; then
    echo "  [ok]   plist:         rendered at $PLIST_SRC"
  else
    echo "  [fail] plist:         missing (run 'cpm init')"
    fails=$((fails+1))
  fi

  if [ -f "$PLIST_DST" ]; then
    if launchctl list "$PLIST_NAME" &>/dev/null; then
      echo "  [ok]   scheduler:     loaded"
    else
      echo "  [warn] scheduler:     installed but not loaded (run 'cpm start')"
    fi
  else
    echo "  [warn] scheduler:     not installed (run 'cpm start' to enable)"
  fi

  if command -v cpm &>/dev/null; then
    echo "  [ok]   cpm on PATH:   yes"
  else
    echo "  [warn] cpm on PATH:   no (optional: ln -s \"$PROJECT_DIR/cpm\" /opt/homebrew/bin/cpm)"
  fi

  if [ -f "$PROJECTS_FILE" ] && jq -e '.projects' "$PROJECTS_FILE" &>/dev/null; then
    local bad
    bad=$(jq -r '.projects[] | select(.trigger_id == null or .trigger_id == "" or (.trigger_id | startswith("trig_REPLACE"))) | .name' "$PROJECTS_FILE")
    if [ -n "$bad" ]; then
      while IFS= read -r project_name; do
        echo "  [fail] $project_name: trigger_id missing or still a placeholder"
        fails=$((fails+1))
      done <<< "$bad"
    fi
  fi

  echo ""
  if [ "$fails" -eq 0 ]; then
    echo "All checks passed."
    exit 0
  else
    echo "$fails check(s) failed."
    exit 1
  fi
}

# --- Subcommand: prompt ---
cmd_prompt() {
  shift  # remove "prompt" from args
  local prompt_file="$PROJECT_DIR/prompts/routine.md"
  local copy=false save=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --copy) copy=true; shift ;;
      --save) save="$2"; shift 2 ;;
      *) echo "Unknown option: $1"; exit 1 ;;
    esac
  done

  if [ ! -f "$prompt_file" ]; then
    echo "Error: prompt file not found at $prompt_file"
    exit 1
  fi

  if [ "$copy" = true ]; then
    if ! command -v pbcopy &>/dev/null; then
      echo "Error: pbcopy not available (macOS only)"
      exit 1
    fi
    pbcopy < "$prompt_file"
    echo "Copied $prompt_file to clipboard ($(wc -l < "$prompt_file" | tr -d ' ') lines)"
  elif [ -n "$save" ]; then
    cp "$prompt_file" "$save"
    echo "Saved to $save"
  else
    cat "$prompt_file"
  fi
}

# --- Subcommand: start ---
cmd_start() {
  if ! [ -f "$PLIST_SRC" ]; then
    echo "Error: plist not found at $PLIST_SRC"
    exit 1
  fi

  mkdir -p "$HOME/Library/LaunchAgents"
  mkdir -p "$LOG_DIR"
  cp "$PLIST_SRC" "$PLIST_DST"

  # Unload first if already loaded
  launchctl unload "$PLIST_DST" 2>/dev/null || true
  launchctl load "$PLIST_DST"

  echo "Orchestrator started (runs every 30 minutes)"
  echo "Logs: $LOG_DIR"
}

# --- Subcommand: stop ---
cmd_stop() {
  if launchctl list "$PLIST_NAME" &>/dev/null; then
    launchctl unload "$PLIST_DST"
    echo "Orchestrator stopped"
  else
    echo "Orchestrator is not running"
  fi
}

# --- Subcommand: logs ---
cmd_logs() {
  mkdir -p "$LOG_DIR"
  local latest
  latest=$(ls -t "$LOG_DIR"/orchestrator-*.log 2>/dev/null | head -1)

  if [ -z "$latest" ]; then
    echo "No log files found in $LOG_DIR"
    echo "Run 'cpm run' first to generate logs."
    exit 0
  fi

  echo "Tailing $latest (Ctrl+C to stop)"
  echo "---"
  tail -f "$latest"
}

_append_project_to_registry() {
  local name="$1" trigger_id="$2" branch_prefix="$3"
  shift 3
  local -a repos=("$@")

  if [ -z "$name" ]; then
    echo "Error: name is required" >&2
    return 1
  fi
  if [ ${#repos[@]} -eq 0 ]; then
    echo "Error: at least one repo is required" >&2
    return 1
  fi
  if [ -z "$trigger_id" ]; then
    echo "Error: trigger_id is required" >&2
    return 1
  fi

  if [ ! -f "$PROJECTS_FILE" ]; then
    echo '{"projects": []}' > "$PROJECTS_FILE"
  fi

  if jq -e --arg n "$name" '.projects[] | select(.name == $n)' "$PROJECTS_FILE" >/dev/null 2>&1; then
    echo "Error: project '$name' already exists" >&2
    return 1
  fi

  local repos_json="["
  local first=true
  for r in "${repos[@]}"; do
    [ "$first" = "true" ] && first=false || repos_json+=","
    repos_json+="{\"repo\":\"$r\"}"
  done
  repos_json+="]"

  local project_json
  project_json=$(jq -n \
    --arg name "$name" \
    --argjson repos "$repos_json" \
    --arg trigger "$trigger_id" \
    '{name: $name, repos: $repos, trigger_id: $trigger, paused: false}')

  if [ -n "$branch_prefix" ]; then
    project_json=$(echo "$project_json" | jq --arg p "$branch_prefix" '. + {branch_prefix: $p}')
  fi

  jq --argjson proj "$project_json" '.projects += [$proj]' "$PROJECTS_FILE" > "$PROJECTS_FILE.tmp" \
    && mv "$PROJECTS_FILE.tmp" "$PROJECTS_FILE"

  echo "$project_json"
}

# --- Subcommand: add ---
cmd_add() {
  shift  # remove "add" from args

  local name="" trigger_id="" branch_prefix=""
  local -a repos=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)       name="$2"; shift 2 ;;
      --repo)       repos+=("$2"); shift 2 ;;
      --trigger)    trigger_id="$2"; shift 2 ;;
      --prefix)     branch_prefix="$2"; shift 2 ;;
      *)
        echo "Unknown option: $1"
        echo "Usage: cpm add --name <name> --repo <owner/repo> [--repo <owner/repo>] --trigger <trigger_id> [--prefix <branch_prefix>]"
        exit 1
        ;;
    esac
  done

  local result
  result=$(_append_project_to_registry "$name" "$trigger_id" "$branch_prefix" "${repos[@]}") || exit 1

  echo "Added project '$name'"
  echo "$result" | jq .
}

# --- Subcommand: new ---
cmd_new() {
  shift  # remove "new" from args

  local positional_name=""
  if [ $# -gt 0 ] && [[ "$1" != --* ]]; then
    positional_name="$1"
    shift
  fi

  # If flags are present, delegate to cmd_add (non-interactive path)
  if [ $# -gt 0 ]; then
    local -a forwarded=("add")
    [ -n "$positional_name" ] && forwarded+=("--name" "$positional_name")
    forwarded+=("$@")
    cmd_add "${forwarded[@]}"
    return
  fi

  # Interactive wizard
  echo "Setting up a new project for cpm."
  echo ""

  local name="$positional_name"
  while [ -z "$name" ]; do
    read "name?Project name (lowercase, hyphenated, used in cpm status): "
  done

  local repos_input=""
  while [ -z "$repos_input" ]; do
    read "repos_input?GitHub repos (space-separated owner/name): "
  done
  local -a repos=("${(@s: :)repos_input}")

  local branch_prefix=""
  read "branch_prefix?Branch prefix [claude/]: "

  echo ""
  echo "Step 1: Write your phased plan."
  echo ""
  echo "  In your project repo:"
  echo "    cpm prompt --copy"
  echo "  Paste into Claude Code with a description of what you want to build."
  echo "  Claude writes docs/plans/<name>.md. Commit and push to main."
  echo ""
  local _ack=""
  read "_ack?Press enter once the plan is committed (Ctrl-C to abort) "

  echo ""
  echo "Step 2: Create a Claude routine."
  echo ""
  echo "  In Claude Code (in your project repo), create a new routine with the"
  echo "  same prompt. Save it, then copy its Trigger ID."
  echo ""

  local trigger_id=""
  while [ -z "$trigger_id" ]; do
    read "trigger_id?Trigger ID (looks like trig_abc...): "
  done

  echo ""
  echo "Adding project to cpm registry..."

  local result
  result=$(_append_project_to_registry "$name" "$trigger_id" "$branch_prefix" "${repos[@]}") || exit 1

  echo "  [ok] $name added (${#repos[@]} repo(s))"
  echo ""
  echo "Next steps:"
  echo "  cpm trigger $name    # fire phase 0 manually to kick things off"
  echo "  cpm status           # see project state"
}

# --- Subcommand: remove ---
cmd_remove() {
  local name="${2:-}"

  if [ -z "$name" ]; then
    echo "Usage: cpm remove <name>"
    exit 1
  fi

  if ! jq -e --arg n "$name" '.projects[] | select(.name == $n)' "$PROJECTS_FILE" >/dev/null 2>&1; then
    echo "Error: project '$name' not found"
    exit 1
  fi

  jq --arg n "$name" 'del(.projects[] | select(.name == $n))' "$PROJECTS_FILE" > "$PROJECTS_FILE.tmp" \
    && mv "$PROJECTS_FILE.tmp" "$PROJECTS_FILE"

  echo "Removed project '$name'"
}

# --- Subcommand: pause / resume ---
_set_paused() {
  local name="$1" value="$2"

  if ! jq -e --arg n "$name" '.projects[] | select(.name == $n)' "$PROJECTS_FILE" >/dev/null 2>&1; then
    echo "Error: project '$name' not found"
    exit 1
  fi

  jq --arg n "$name" --argjson v "$value" \
    '(.projects[] | select(.name == $n) | .paused) = $v' \
    "$PROJECTS_FILE" > "$PROJECTS_FILE.tmp" \
    && mv "$PROJECTS_FILE.tmp" "$PROJECTS_FILE"
}

cmd_pause() {
  local name="${2:-}"
  if [ -z "$name" ]; then
    echo "Usage: cpm pause <name>"
    exit 1
  fi
  _set_paused "$name" "true"
  echo "Paused '$name'"
}

cmd_resume() {
  local name="${2:-}"
  if [ -z "$name" ]; then
    echo "Usage: cpm resume <name>"
    exit 1
  fi
  _set_paused "$name" "false"
  echo "Resumed '$name'"
}

# --- Subcommand: trigger ---
cmd_trigger() {
  local name="${2:-}"

  if [ -z "$name" ]; then
    echo "Usage: cpm trigger <name>"
    exit 1
  fi

  local project
  project=$(jq -e --arg n "$name" '.projects[] | select(.name == $n)' "$PROJECTS_FILE" 2>/dev/null) || true

  if [ -z "$project" ]; then
    echo "Error: project '$name' not found"
    exit 1
  fi

  local trigger_id
  trigger_id=$(echo "$project" | jq -r '.trigger_id')

  log "[$name] Manual dispatch: trigger $trigger_id"

  dispatch_output=$(claude -p \
    --allowed-tools "RemoteTrigger" \
    --dangerously-skip-permissions \
    --no-session-persistence \
    "Run the remote trigger with ID $trigger_id. Use the RemoteTrigger tool with action 'run' and trigger_id '$trigger_id'. Output only the result." \
    2>&1) || true

  echo "$dispatch_output"
}

# --- Main ---
case "${1:-help}" in
  init)   cmd_init "$@" ;;
  doctor) cmd_doctor ;;
  prompt) cmd_prompt "$@" ;;
  new)    cmd_new "$@" ;;
  run)    cmd_run ;;
  status) cmd_status ;;
  start)  cmd_start ;;
  stop)   cmd_stop ;;
  logs)   cmd_logs ;;
  add)    cmd_add "$@" ;;
  remove) cmd_remove "$@" ;;
  pause)  cmd_pause "$@" ;;
  resume) cmd_resume "$@" ;;
  trigger) cmd_trigger "$@" ;;
  help|--help|-h)
    echo "Usage: cpm <command>"
    echo ""
    echo "Setup:"
    echo "  init     Generate plist + empty projects.json (one-time setup)"
    echo "  doctor   Check dependencies, auth, and project configuration"
    echo ""
    echo "Commands:"
    echo "  run      Execute the orchestrator once"
    echo "  start    Enable the scheduler (every 30 min)"
    echo "  stop     Disable the scheduler"
    echo "  status   Show project states and scheduler status"
    echo "  logs     Tail recent orchestrator logs"
    echo "  new      Add a project via an interactive wizard"
    echo "  add      Add a project to the registry (flag-based)"
    echo "  remove   Remove a project from the registry"
    echo "  pause    Pause a project (skip during orchestrator runs)"
    echo "  resume   Resume a paused project"
    echo "  trigger  Manually dispatch a project's routine"
    echo "  prompt   Print the routine prompt (use with --copy or --save)"
    echo ""
    echo "Add usage:"
    echo "  cpm add --name <name> --repo <owner/repo> [--repo <owner/repo>] --trigger <trigger_id> [--prefix <branch_prefix>]"
    echo ""
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'cpm help' for usage"
    exit 1
    ;;
esac
